# Anthropic — get from console.anthropic.com
# Used for LLM (Claude Sonnet) in Parts 4+
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — get from dash.voyageai.com
# Used for embedding generation (voyage-3-large, 1024 dims)
VOYAGE_API_KEY=pa-...

# Postgres (used if you override docker defaults)
DATABASE_URL=jdbc:postgresql://localhost:5432/gtmzero

# Frontend — points at local backend by default
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
